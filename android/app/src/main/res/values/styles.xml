<style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
    <item name="colorPrimary">@color/colorPrimary</item>
    <item name="colorPrimaryDark">#FF000000</item> <!-- SİYAH -->
    <item name="colorAccent">@color/colorAccent</item>

    <!-- BU SATIRLAR ÇOK ÖNEMLİ -->
    <item name="android:statusBarColor">#FF000000</item> <!-- SİYAH -->
    <item name="android:windowLightStatusBar">false</item> <!-- BEYAZ ikonlar -->
    <item name="android:windowLightNavigationBar">false</item>
    
    <!-- Transparency ile oynamayı kesinlikle engelle -->
    <item name="android:windowTranslucentStatus">false</item>
    <item name="android:windowTranslucentNavigation">false</item>
    <item name="android:fitsSystemWindows">true</item>
    <item name="android:windowIsTranslucent">false</item>
    <item name="android:windowDrawsSystemBarBackgrounds">true</item>
</style>
